rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOrganizer() {
      return request.auth != null && request.auth.uid in [
        "BEqkx94a5PdGb34ZQtoEALKfyi13",
        "TeNT8ahVb1UeB8uTavjd2VghKtL2"
      ];
    }

    match /contest/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /results/{resultId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'category', 'solves', 'ao5', 'ao5ms', 'timestamp', 'status'])
        && request.resource.data.name      is string
        && request.resource.data.email     is string
        && request.resource.data.category  is string
        && request.resource.data.solves    is list
        && request.resource.data.email.matches('.*@.*')
        && request.resource.data.solves.size() <= 5
        // Competidores solo pueden crear con status 'pending'
        && request.resource.data.status == 'pending';

      // Solo el organizador puede cambiar el status
      allow update: if isOrganizer()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['approved', 'rejected', 'pending'];

      allow delete: if isOrganizer();
    }

    match /participants/{participantId} {
      allow read:   if isOrganizer();

      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'category', 'timestamp'])
        && request.resource.data.name     is string
        && request.resource.data.email    is string
        && request.resource.data.category is string
        && request.resource.data.email.matches('.*@.*');

      allow delete: if isOrganizer();
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
